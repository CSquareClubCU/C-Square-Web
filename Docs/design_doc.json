{
  "designSystem": {
    "name": "Envesty Inspired SaaS Agency Design Language",
    "style": {
      "category": "Modern Premium Startup",
      "subCategory": "B2B SaaS + Agency + Consulting",
      "personality": [
        "Professional",
        "Trustworthy",
        "Premium",
        "Minimal",
        "Execution-focused",
        "Founder-centric"
      ],
      "visualTone": [
        "Clean",
        "High whitespace",
        "Structured",
        "Corporate",
        "Modern"
      ]
    },

    "layout": {
      "maxWidth": "1280px",
      "contentWidth": "1200px",
      "containerPadding": {
        "desktop": "80px",
        "tablet": "40px",
        "mobile": "20px"
      },
      "sectionSpacing": {
        "desktop": "120px",
        "tablet": "80px",
        "mobile": "64px"
      },
      "gridSystem": {
        "desktop": 12,
        "tablet": 8,
        "mobile": 4
      }
    },

    "colorSystem": {
      "theme": "Light",
      "background": "#FFFFFF",
      "surface": "#F8F8F8",
      "card": "#FFFFFF",
      "primaryText": "#111111",
      "secondaryText": "#666666",
      "mutedText": "#888888",
      "border": "#EAEAEA",
      "accent": "#111111",
      "accentHover": "#222222",
      "success": "#0A8F5A"
    },

    "typography": {
      "fontFamily": "Modern Geometric Sans",
      "fallbacks": [
        "Inter",
        "Satoshi",
        "Plus Jakarta Sans"
      ],

      "hero": {
        "size": "64-80px",
        "weight": 700,
        "lineHeight": 1.05,
        "letterSpacing": "-0.04em"
      },

      "h1": {
        "size": "48-60px",
        "weight": 700,
        "lineHeight": 1.1
      },

      "h2": {
        "size": "36-48px",
        "weight": 700,
        "lineHeight": 1.2
      },

      "h3": {
        "size": "24-32px",
        "weight": 600,
        "lineHeight": 1.3
      },

      "body": {
        "size": "16-18px",
        "weight": 400,
        "lineHeight": 1.7
      },

      "small": {
        "size": "14px",
        "weight": 400
      },

      "label": {
        "size": "12-14px",
        "weight": 600,
        "uppercase": true,
        "letterSpacing": "0.12em"
      }
    },

    "buttons": {
      "primary": {
        "background": "#111111",
        "text": "#FFFFFF",
        "borderRadius": "999px",
        "padding": "14px 28px",
        "fontWeight": 600
      },

      "secondary": {
        "background": "transparent",
        "border": "1px solid #DDDDDD",
        "text": "#111111",
        "borderRadius": "999px"
      },

      "hoverEffects": [
        "Subtle opacity change",
        "Slight scale increase",
        "Smooth 200ms transition"
      ]
    },

    "cards": {
      "background": "#FFFFFF",
      "border": "1px solid #EEEEEE",
      "radius": "24px",
      "padding": "32px",
      "shadow": "Very subtle",
      "hover": {
        "translateY": "-4px",
        "shadowIncrease": true
      }
    },

    "navigation": {
      "height": "80px",
      "style": "Minimal",
      "background": "Transparent",
      "logoAlignment": "Left",
      "menuAlignment": "Center",
      "ctaAlignment": "Right"
    },

    "heroSection": {
      "layout": "Centered",
      "headlineWidth": "800px",
      "descriptionWidth": "700px",
      "ctaCount": 2,
      "elements": [
        "Eyebrow label",
        "Large headline",
        "Supporting paragraph",
        "Dual CTA buttons"
      ]
    },

    "sectionPatterns": [
      {
        "name": "Problem Solution",
        "structure": [
          "Section label",
          "Headline",
          "Description",
          "Feature grid"
        ]
      },

      {
        "name": "Process Timeline",
        "structure": [
          "Step number",
          "Illustration",
          "Title",
          "Description"
        ]
      },

      {
        "name": "Service Categories",
        "structure": [
          "Number",
          "Category title",
          "Icon cluster",
          "Description",
          "Capabilities list"
        ]
      },

      {
        "name": "Trust/Testimonial",
        "structure": [
          "Quote",
          "Founder name",
          "Company",
          "Country"
        ]
      },

      {
        "name": "FAQ Accordion",
        "structure": [
          "Question",
          "Expandable answer"
        ]
      }
    ],

    "spacing": {
      "xs": "4px",
      "sm": "8px",
      "md": "16px",
      "lg": "24px",
      "xl": "32px",
      "2xl": "48px",
      "3xl": "64px",
      "4xl": "96px",
      "5xl": "120px"
    },

    "iconography": {
      "style": "Simple outline",
      "strokeWidth": "1.5px",
      "size": "20-24px",
      "color": "#111111"
    },

    "visualPatterns": {
      "corners": "Large rounded corners",
      "containers": "Soft card containers",
      "dividers": "Light gray",
      "shadows": "Minimal",
      "animations": [
        "Fade up on scroll",
        "Staggered card reveal",
        "Button hover transition"
      ]
    },

    "contentStyle": {
      "headlineStyle": "Benefit-driven",
      "tone": "Consultative",
      "sentenceLength": "Short",
      "ctaStyle": "Action-oriented",
      "avoid": [
        "Technical jargon",
        "Complex paragraphs",
        "Marketing fluff"
      ]
    },

    "responsiveRules": {
      "mobileHeroHeadline": "36-42px",
      "mobileSectionSpacing": "64px",
      "mobileCardPadding": "24px",
      "stackColumnsBelow": "768px"
    },

    "aiGenerationRules": [
      "Prefer whitespace over decoration",
      "Use large typography for hierarchy",
      "Keep sections highly structured",
      "Avoid bright colors",
      "Use monochrome palette with one accent",
      "Cards should feel premium and spacious",
      "Every section should have a clear business purpose",
      "Maintain consistent vertical rhythm",
      "Use rounded pill buttons",
      "Use enterprise SaaS aesthetics"
    ]
  }
}