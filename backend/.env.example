# =============================================================================
# C Square Club — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your local environment.
# Never commit .env to version control.
# Production values are set via Azure App Service configuration — not this file.
# =============================================================================


# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------

# Which settings module to use. Change to csquare.settings.production for prod.
DJANGO_SETTINGS_MODULE=csquare.settings.development

# Generate a secure key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-local-secret-key-here


# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Leave empty for development (SQLite is used automatically).
# Required for production — format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=


# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Comma-separated list of allowed frontend origins (production only).
# Example: https://csquare.in,https://www.csquare.in
CORS_ALLOWED_ORIGINS=


# ---------------------------------------------------------------------------
# Frontend URL (used to build magic link URLs in emails)
# ---------------------------------------------------------------------------

FRONTEND_URL=http://localhost:3000


# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------

# The from-address used on all outgoing emails.
NOTIFICATION_EMAIL=csquare.core@gmail.com

# ---------------------------------------------------------------------------
# Email — Gmail SMTP
# ---------------------------------------------------------------------------

# The Gmail address that sends all emails from the platform.
EMAIL_HOST_USER=csquare.core@gmail.com

# Gmail App Password — NOT your Gmail account password.
# How to generate one:
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification (required)
#   3. Go to App Passwords → create one for "Mail" / "Other (Custom)"
#   4. Paste the 16-character password here (no spaces)
EMAIL_HOST_PASSWORD=your-gmail-app-password-here

# Display name and address shown in the From field of all emails.
EMAIL_FROM=C Square Club <csquare.core@gmail.com>


# ---------------------------------------------------------------------------
# Azure Blob Storage
# ---------------------------------------------------------------------------

# Required when storing files in Azure (production or when testing uploads).
# Leave empty in development (local media/ folder is used automatically).
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=csquare-media


# ---------------------------------------------------------------------------
# Deployment
# ---------------------------------------------------------------------------

# Comma-separated list of allowed hostnames for the Django backend.
# Example: api.csquare.in,csquare.azurewebsites.net
ALLOWED_HOSTS=localhost,127.0.0.1
